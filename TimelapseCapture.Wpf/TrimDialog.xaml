<Window x:Class="TimelapseCapture.Wpf.TrimDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="Trim" Width="600" SizeToContent="Height" Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="18">
        <TextBlock Text="TRIM — CHOOSE A FRAME RANGE" Style="{StaticResource CardTitle}"/>

        <Border Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" Height="300" ClipToBounds="True">
            <Image x:Name="preview" Stretch="Uniform"/>
        </Border>

        <!-- Accent band + ticks above the scrubber show the chosen start/end range at a glance. -->
        <Canvas x:Name="rangeCanvas" Height="6" Margin="0,10,0,-8" IsHitTestVisible="False"/>
        <Slider x:Name="scrub" Minimum="1" Margin="0,12,0,0" local:WheelStep.Amount="1"
                IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="10"/>

        <!-- Frame-precise stepping (hold to repeat) — scrubbing alone is too coarse on big sessions. -->
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <RepeatButton Grid.Column="0" Content="&#9664;&#9664; 10" Tag="-10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Back 10 frames (hold to repeat)."/>
            <RepeatButton Grid.Column="1" Content="&#9664; 1" Tag="-1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="6,0,0,0"
                          ToolTip="Back one frame (hold to repeat)."/>
            <TextBlock Grid.Column="2" x:Name="posText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"/>
            <RepeatButton Grid.Column="3" Content="1 &#9654;" Tag="1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="0,0,6,0"
                          ToolTip="Forward one frame (hold to repeat)."/>
            <RepeatButton Grid.Column="4" Content="10 &#9654;&#9654;" Tag="10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Forward 10 frames (hold to repeat)."/>
        </Grid>
        <TextBlock Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"
                   Text="Keys:  &#8592;/&#8594; step 1  ·  Shift+&#8592;/&#8594; step 10  ·  S set start  ·  E set end"/>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Set start" Style="{StaticResource BtnBase}" Click="OnSetStart" Margin="0,0,8,0"
                    ToolTip="Use the current frame as the first frame of the clip."/>
            <Button Content="Set end" Style="{StaticResource BtnBase}" Click="OnSetEnd" Margin="0,0,14,0"
                    ToolTip="Use the current frame as the last frame of the clip."/>
            <TextBlock x:Name="rangeText" Style="{StaticResource Body}" FontFamily="Consolas" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Shown when the session overshot the Stats target — one click clips to the planned length. -->
        <StackPanel x:Name="targetRow" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
            <TextBlock x:Name="targetText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       VerticalAlignment="Center"/>
            <Button Content="Clip to target" Style="{StaticResource BtnBase}" Click="OnClipToTarget" Margin="10,0,0,0"
                    ToolTip="Set the range to frames 1 through the target, matching your planned video length."/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
            <Button Content="Encode selection" Style="{StaticResource BtnPrimary}" Click="OnEncode" MinWidth="130"/>
        </StackPanel>
    </StackPanel>
</Window>
