<Window x:Class="TimelapseCapture.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TimelapseCapture.Wpf.ViewModels"
        Title="Timelapse Capture" Height="660" Width="920"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#128247;" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Timelapse Capture" Style="{StaticResource H1}" VerticalAlignment="Center"/>
            </StackPanel>
            <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceAltBrush}"
                    CornerRadius="14" Padding="12,6"
                    BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                <TextBlock Text="{Binding SessionName}" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">

                <!-- Output -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="OUTPUT FOLDER" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding OutputFolder}" FontFamily="Consolas"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <Button Grid.Column="1" Content="Choose&#8230;" Style="{StaticResource BtnBase}"
                                    Command="{Binding ChooseFolderCommand}" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Session -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SESSION" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="New Session" Style="{StaticResource BtnPrimary}"
                                    Command="{Binding NewSessionCommand}"/>
                            <Button Grid.Column="1" Content="&#128194;  Open Folder" Style="{StaticResource BtnBase}"
                                    Command="{Binding OpenFolderCommand}" Margin="8,0,0,0"
                                    ToolTip="Open the session folder in Explorer"/>
                            <TextBlock Grid.Column="2" Text="{Binding SessionName}" Style="{StaticResource Body}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Region" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding RegionText}" FontFamily="Consolas" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Select Region" Style="{StaticResource BtnBase}"
                                        Command="{Binding SelectRegionCommand}" Margin="0,0,8,0"/>
                                <Button Content="Full Screen" Style="{StaticResource BtnBase}"
                                        Command="{Binding FullScreenCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Capture control -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CAPTURE" Style="{StaticResource CardTitle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Interval" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding IntervalSeconds}" Style="{StaticResource DarkTextBox}" Width="56" TextAlignment="Center"/>
                            <TextBlock Text="seconds" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource Muted}" Margin="0,0,0,14" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="&#9654;  Start" Style="{StaticResource BtnSuccess}"
                                    Command="{Binding StartCommand}" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="&#9209;  Stop" Style="{StaticResource BtnBase}"
                                    Command="{Binding StopCommand}"/>
                            <TextBlock Grid.Column="2" Text="{Binding FrameCountText}" FontFamily="Consolas" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="&#127916;  Encode Video" Style="{StaticResource BtnPrimary}"
                                    Command="{Binding EncodeCommand}"/>
                            <TextBlock Grid.Column="1" Text="{Binding EncodeStatus}" Style="{StaticResource Muted}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Right column: status -->
            <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="STATUS" Style="{StaticResource CardTitle}"/>
                    <StackPanel Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FFmpeg" Style="{StaticResource Muted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FfmpegStatus}" Style="{StaticResource Body}" TextWrapping="Wrap"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="64,8,0,0">
                            <Button Content="Download" Style="{StaticResource BtnBase}" FontSize="12" Padding="10,4"
                                    Command="{Binding DownloadFfmpegCommand}" Margin="0,0,6,0"/>
                            <Button Content="Browse&#8230;" Style="{StaticResource BtnBase}" FontSize="12" Padding="10,4"
                                    Command="{Binding BrowseFfmpegCommand}" Margin="0,0,6,0"/>
                            <Button Content="Cancel" Style="{StaticResource BtnBase}" FontSize="12" Padding="10,4"
                                    Command="{Binding CancelDownloadCommand}"/>
                        </StackPanel>
                    </StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Session" Style="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SessionName}" Style="{StaticResource Body}" TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Region" Style="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="1" Text="{Binding RegionText}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Frames" Style="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="1" Text="{Binding FrameCountText}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
