<Window x:Class="TimelapseCapture.Wpf.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="FrameWrite" SizeToContent="WidthAndHeight" MinWidth="360" MaxWidth="560"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="22,20,22,18">
        <StackPanel Orientation="Horizontal">
            <Border x:Name="iconBadge" Width="36" Height="36" CornerRadius="18" VerticalAlignment="Top" Margin="0,0,16,0">
                <TextBlock x:Name="iconGlyph" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"/>
            </Border>
            <TextBlock x:Name="messageText" TextWrapping="Wrap" MaxWidth="440" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" LineHeight="19"/>
        </StackPanel>
        <!-- Shown only via ShowWithSuppress — repeat-prone confirmations offer a way out. -->
        <CheckBox x:Name="dontAskBox" Content="Don't ask me again" Visibility="Collapsed"
                  Margin="52,14,0,0" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                  ToolTip="Skip this confirmation from now on (answering Yes automatically). Undo anytime in Settings → “Reset ‘don't ask again’ answers”."/>
        <StackPanel x:Name="buttonPanel" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
