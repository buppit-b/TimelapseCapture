<Window x:Class="TimelapseCapture.Wpf.MonitorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose a monitor" Width="420" SizeToContent="Height" MaxHeight="520"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="FULL SCREEN — WHICH MONITOR?" Style="{StaticResource CardTitle}"/>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" CornerRadius="10" Padding="6">
            <ListBox x:Name="list" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="OnDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                            BorderThickness="1" BorderBrush="Transparent" Padding="8,7" Margin="0,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="Consolas" FontSize="14"/>
                            <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
            <Button Content="Use monitor" Style="{StaticResource BtnPrimary}" Click="OnOk" MinWidth="84"/>
        </StackPanel>
    </Grid>
</Window>
