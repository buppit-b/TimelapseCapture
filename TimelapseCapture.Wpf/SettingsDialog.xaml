<Window x:Class="TimelapseCapture.Wpf.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="Settings" Width="460" SizeToContent="Height" MaxHeight="780"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="18">
        <TextBlock Text="SETTINGS" Style="{StaticResource CardTitle}"/>

        <!-- Appearance -->
        <ToggleButton x:Name="secAppearance" Style="{StaticResource SectionHeader}" Content="APPEARANCE" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secAppearance, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Theme" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Terminal"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Terminal}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ocean"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ocean}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ember"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ember}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Synth"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Synth}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Light"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Light}"/>
            </StackPanel>
        </StackPanel>

        <!-- Window -->
        <ToggleButton x:Name="secWindow" Style="{StaticResource SectionHeader}" Content="WINDOW" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secWindow, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Keep window always on top" IsChecked="{Binding AlwaysOnTop}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Keep the Timelapse Capture window above other windows while you work."/>
            <CheckBox Content="Hide this window from screen capture" IsChecked="{Binding HideFromCapture}"
                      Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0"
                      ToolTip="Exclude the Timelapse Capture window from screen captures (yours and others') so it never appears in frames. Win10 2004+."/>
        </StackPanel>

        <!-- Capture -->
        <ToggleButton x:Name="secCapture" Style="{StaticResource SectionHeader}" Content="CAPTURE" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secCapture, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Capture the mouse cursor in frames" IsChecked="{Binding CaptureCursor}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Draw the mouse pointer into each captured frame (takes effect on the next capture start)."/>
            <CheckBox Content="Overlay text on frames" IsChecked="{Binding OverlayTimestamp}"
                      Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0"
                      ToolTip="Burn a text overlay into each frame (takes effect on the next capture start)."/>
            <StackPanel Margin="22,6,0,0" Visibility="{Binding OverlayTimestamp, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Text" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                    <TextBox Text="{Binding OverlayText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"
                             Width="290"
                             ToolTip="Tokens: {datetime} {date} {time} {time12} · {t:FORMAT} for a custom .NET date format · plus any literal text."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Where" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2196;"
                                 IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=0}" ToolTip="Top-left"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2197;"
                                 IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=1}" ToolTip="Top-right"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2199;"
                                 IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=2}" ToolTip="Bottom-left"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2198;"
                                 IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=3}" ToolTip="Bottom-right"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Font" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                    <TextBox Text="{Binding OverlayFontFamily}" Style="{StaticResource DarkTextBox}" Width="150"
                             ToolTip="Font family name, e.g. Consolas, Arial, Segoe UI."/>
                    <TextBlock Text="Size" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                    <TextBox Text="{Binding OverlayFontSize}" Style="{StaticResource DarkTextBox}" Width="50" TextAlignment="Center"
                             local:NumericInput.AllowDecimal="False"
                             ToolTip="Pixels; 0 = auto-scale to the frame height."/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Encoding -->
        <ToggleButton x:Name="secEncoding" Style="{StaticResource SectionHeader}" Content="ENCODING" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secEncoding, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Open the output folder when encoding finishes" IsChecked="{Binding OpenFolderAfterEncode}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Automatically open the video's folder after a successful encode, without asking."/>
        </StackPanel>

        <!-- Hotkey -->
        <ToggleButton x:Name="secHotkey" Style="{StaticResource SectionHeader}" Content="HOTKEY" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secHotkey, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Enable global start/stop hotkey" IsChecked="{Binding HotkeysEnabled}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Register a system-wide hotkey to start/stop capture without focusing this window."/>
            <StackPanel Margin="22,6,0,0" Visibility="{Binding HotkeysEnabled, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Shortcut" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="58"/>
                    <TextBox x:Name="hotkeyBox" IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Hand"
                             Style="{StaticResource DarkTextBox}" Width="200" PreviewKeyDown="OnHotkeyKeyDown"/>
                </StackPanel>
                <TextBlock Text="Click the box above, then press your combination (must include Ctrl, Shift or Alt)."
                           Style="{StaticResource Muted}" FontSize="10" Margin="58,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="versionText" Style="{StaticResource Muted}" FontSize="11" Margin="0,16,0,0"/>
        <Grid Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Export&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ExportSettingsCommand}"
                        Margin="0,0,8,0" ToolTip="Save all preferences to a file."/>
                <Button Content="Import&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ImportSettingsCommand}"
                        ToolTip="Load preferences from a file."/>
            </StackPanel>
            <Button Content="Close" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                    MinWidth="84" IsCancel="True"/>
        </Grid>
    </StackPanel>
</Window>
