<Window x:Class="TimelapseCapture.Wpf.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="Settings" Width="460" SizeToContent="Height" MaxHeight="780"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="18">
        <TextBlock Text="SETTINGS" Style="{StaticResource CardTitle}"/>

        <!-- Appearance -->
        <ToggleButton x:Name="secAppearance" Style="{StaticResource SectionHeader}" Content="APPEARANCE" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secAppearance, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Theme" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Terminal"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Terminal}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ocean"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ocean}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ember"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ember}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Synth"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Synth}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Light"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Light}"/>
            </StackPanel>
        </StackPanel>

        <!-- Encoding -->
        <ToggleButton x:Name="secEncoding" Style="{StaticResource SectionHeader}" Content="ENCODING" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secEncoding, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Open the output folder when encoding finishes" IsChecked="{Binding OpenFolderAfterEncode}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Automatically open the video's folder after a successful encode, without asking."/>
        </StackPanel>

        <!-- Hotkey -->
        <ToggleButton x:Name="secHotkey" Style="{StaticResource SectionHeader}" Content="HOTKEY" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secHotkey, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Enable global start/stop hotkey" IsChecked="{Binding HotkeysEnabled}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Register a system-wide hotkey to start/stop capture without focusing this window."/>
            <StackPanel Margin="22,6,0,0" Visibility="{Binding HotkeysEnabled, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Shortcut" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="58"/>
                    <TextBox x:Name="hotkeyBox" IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Hand"
                             Style="{StaticResource DarkTextBox}" Width="200" PreviewKeyDown="OnHotkeyKeyDown"/>
                </StackPanel>
                <TextBlock Text="Click the box above, then press your combination (must include Ctrl, Shift or Alt)."
                           Style="{StaticResource Muted}" FontSize="10" Margin="58,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="versionText" Style="{StaticResource Muted}" FontSize="11" Margin="0,16,0,0"/>
        <Grid Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Export&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ExportSettingsCommand}"
                        Margin="0,0,8,0" ToolTip="Save all preferences to a file."/>
                <Button Content="Import&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ImportSettingsCommand}"
                        ToolTip="Load preferences from a file."/>
            </StackPanel>
            <Button Content="Close" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                    MinWidth="84" IsCancel="True"/>
        </Grid>
    </StackPanel>
</Window>
