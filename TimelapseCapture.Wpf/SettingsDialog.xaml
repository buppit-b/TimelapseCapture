<Window x:Class="TimelapseCapture.Wpf.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="380" SizeToContent="Height" Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="18">
        <TextBlock Text="SETTINGS" Style="{StaticResource CardTitle}"/>
        <CheckBox Content="Keep window always on top" IsChecked="{Binding AlwaysOnTop}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  ToolTip="Keep the Timelapse Capture window above other windows while you work."/>
        <CheckBox Content="Capture the mouse cursor in frames" IsChecked="{Binding CaptureCursor}"
                  Foreground="{StaticResource TextPrimaryBrush}" Margin="0,10,0,0"
                  ToolTip="Draw the mouse pointer into each captured frame (takes effect on the next capture start)."/>
        <TextBlock Text="More preferences will live here as the app grows."
                   Style="{StaticResource Muted}" FontSize="11" Margin="0,14,0,0" TextWrapping="Wrap"/>
        <Button Content="Close" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                Margin="0,18,0,0" MinWidth="84" IsCancel="True"/>
    </StackPanel>
</Window>
