<Window x:Class="TimelapseCapture.Wpf.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="Settings" Width="460" SizeToContent="Height" MaxHeight="780"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="18">
        <TextBlock Text="SETTINGS" Style="{StaticResource CardTitle}"/>

        <!-- Appearance -->
        <ToggleButton x:Name="secAppearance" Style="{StaticResource SectionHeader}" Content="APPEARANCE" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secAppearance, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Theme" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Terminal"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Terminal}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ocean"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ocean}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Ember"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Ember}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Synth"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Synth}"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="theme" Content="Light"
                             IsChecked="{Binding Theme, Converter={StaticResource StrEq}, ConverterParameter=Light}"/>
            </StackPanel>
        </StackPanel>

        <!-- Window tracking -->
        <ToggleButton x:Name="secTracking" Style="{StaticResource SectionHeader}" Content="WINDOW TRACKING" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secTracking, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Keep waiting if the tracked window is minimized" IsChecked="{Binding PauseOnTrackedMinimize}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="When tracking a window: off (default) = stop capturing if it's minimized; on = pause and resume automatically when you restore it."/>
            <CheckBox Content="Keep the tracked window on top while capturing" IsChecked="{Binding KeepTrackedWindowOnTop}"
                      Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,0"
                      ToolTip="Force the tracked window above all others while capturing so nothing can cover it. Released when capture stops."/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="On resize" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="64"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="resize" Content="Lock size"
                             IsChecked="{Binding TrackResizeMode, Converter={StaticResource StrEq}, ConverterParameter=0}"
                             ToolTip="Capture a fixed box at the window's top-left — if the window grows, the extra is cropped (default)."/>
                <RadioButton Style="{StaticResource Seg}" GroupName="resize" Content="Fit"
                             IsChecked="{Binding TrackResizeMode, Converter={StaticResource StrEq}, ConverterParameter=1}"
                             ToolTip="Scale the whole window into the frame, preserving aspect (letterbox) — follows resizing/maximising with nothing cut off."/>
                <RadioButton Style="{StaticResource Seg}" GroupName="resize" Content="Stretch"
                             IsChecked="{Binding TrackResizeMode, Converter={StaticResource StrEq}, ConverterParameter=2}"
                             ToolTip="Scale the whole window to fill the frame, ignoring aspect (may distort)."/>
            </StackPanel>
            <TextBlock Text="Frame size is still fixed (set when you press Track); this only changes how a resized window maps into it. Applies on the next start."
                       Style="{StaticResource Muted}" FontSize="10" Margin="64,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Capture safety -->
        <ToggleButton x:Name="secSafety" Style="{StaticResource SectionHeader}" Content="CAPTURE SAFETY" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secSafety, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Stop capturing when disk space runs low" IsChecked="{Binding AutoStopOnLowDisk}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Automatically stop a run before the drive fills up — a full disk fails frame writes and can disrupt other apps. Watches the disk your active session writes to (shown in Stats). Recommended on for long unattended captures."/>
            <StackPanel Orientation="Horizontal" Margin="22,8,0,0"
                        Visibility="{Binding AutoStopOnLowDisk, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Stop below" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding LowDiskStopMB}" Style="{StaticResource DarkTextBox}" Width="64" TextAlignment="Center"
                         Margin="8,0,8,0" local:NumericInput.AllowDecimal="False"
                         ToolTip="Free-space threshold in megabytes."/>
                <TextBlock Text="MB free" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
            </StackPanel>

            <CheckBox Content="Stop after a maximum duration" IsChecked="{Binding MaxDurationEnabled}"
                      Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"
                      ToolTip="Automatically stop a run after this much accumulated capture time — a hard cap for unattended runs."/>
            <StackPanel Orientation="Horizontal" Margin="22,8,0,0"
                        Visibility="{Binding MaxDurationEnabled, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Stop after" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                <TextBox Text="{Binding MaxDurationMinutes}" Style="{StaticResource DarkTextBox}" Width="64" TextAlignment="Center"
                         Margin="8,0,8,0" local:NumericInput.AllowDecimal="False"
                         ToolTip="Minutes of accumulated capture time (e.g. 480 = 8 hours)."/>
                <TextBlock Text="minutes" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
            </StackPanel>

            <CheckBox Content="Notify (sound + taskbar flash) when a capture or encode finishes"
                      IsChecked="{Binding NotifyOnFinish}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,12,0,0"
                      ToolTip="Play a sound and flash the taskbar when a capture auto-stops (target / disk / duration) or an encode completes."/>
        </StackPanel>

        <!-- Encoding -->
        <ToggleButton x:Name="secEncoding" Style="{StaticResource SectionHeader}" Content="ENCODING" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secEncoding, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Open the output folder when encoding finishes" IsChecked="{Binding OpenFolderAfterEncode}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Automatically open the video's folder after a successful encode, without asking."/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="File name" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="64"/>
                <TextBox Text="{Binding OutputNameTemplate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"
                         Width="250"
                         ToolTip="Base name for encoded and trimmed videos (no extension). Duplicates get _2, _3…"/>
            </StackPanel>
            <TextBlock Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="10" Margin="64,4,0,0" TextWrapping="Wrap"
                       Text="Tokens: {session} {date} {time} {datetime}  ·  .mp4 is added automatically"/>
        </StackPanel>

        <!-- Hotkey -->
        <ToggleButton x:Name="secHotkey" Style="{StaticResource SectionHeader}" Content="HOTKEY" IsChecked="True"/>
        <StackPanel Margin="20,0,0,0" Visibility="{Binding IsChecked, ElementName=secHotkey, Converter={StaticResource BoolToVis}}">
            <CheckBox Content="Enable global start/stop hotkey" IsChecked="{Binding HotkeysEnabled}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      ToolTip="Register a system-wide hotkey to start/stop capture without focusing this window."/>
            <StackPanel Margin="22,6,0,0" Visibility="{Binding HotkeysEnabled, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Shortcut" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="58"/>
                    <TextBox x:Name="hotkeyBox" IsReadOnly="True" IsReadOnlyCaretVisible="False" Cursor="Hand"
                             Style="{StaticResource DarkTextBox}" Width="200" PreviewKeyDown="OnHotkeyKeyDown"/>
                </StackPanel>
                <TextBlock Text="Click the box above, then press your combination (must include Ctrl, Shift or Alt)."
                           Style="{StaticResource Muted}" FontSize="10" Margin="58,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="versionText" Style="{StaticResource Muted}" FontSize="11" Margin="0,16,0,0"/>
        <Grid Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Export&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ExportSettingsCommand}"
                        Margin="0,0,8,0" ToolTip="Save all preferences to a file."/>
                <Button Content="Import&#8230;" Style="{StaticResource BtnBase}" Command="{Binding ImportSettingsCommand}"
                        ToolTip="Load preferences from a file."/>
                <Button Content="Open log" Style="{StaticResource BtnBase}" Command="{Binding OpenLogCommand}" Margin="8,0,0,0"
                        ToolTip="Open the diagnostics log — useful if something went wrong."/>
                <Button Content="Setup wizard&#8230;" Style="{StaticResource BtnBase}" Command="{Binding OpenWizardCommand}" Margin="8,0,0,0"
                        ToolTip="Re-run the guided first-time setup (folder, capture area, speed)."/>
            </StackPanel>
            <Button Content="Close" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                    MinWidth="84" IsCancel="True"/>
        </Grid>
    </StackPanel>
</Window>
