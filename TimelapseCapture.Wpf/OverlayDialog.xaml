<Window x:Class="TimelapseCapture.Wpf.OverlayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TimelapseCapture.Wpf"
        Title="Overlay" Width="560" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="18">
        <TextBlock Text="FRAME OVERLAY" Style="{StaticResource CardTitle}"/>
        <TextBlock Text="Burn text into every captured frame — handy for stamping the date/time onto a timelapse."
                   Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <CheckBox Content="Overlay text on frames" IsChecked="{Binding OverlayTimestamp}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  ToolTip="Burn a text overlay into each frame (takes effect on the next capture start). Off by default."/>

        <StackPanel Margin="0,12,0,0" Visibility="{Binding OverlayTimestamp, Converter={StaticResource BoolToVis}}">
            <!-- Live example, rendered by the SAME code that burns the overlay into frames, at the real
                 frame size (latest frame as the backdrop when one exists) — adjust, see, then record. -->
            <Border Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1" Height="270" ClipToBounds="True">
                <Image x:Name="previewImage" Stretch="Uniform"/>
            </Border>
            <TextBlock x:Name="previewCaption" Style="{StaticResource Muted}" FontSize="10" Margin="0,4,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="Text" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <TextBox Text="{Binding OverlayText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBox}"
                         Width="380"
                         ToolTip="Tokens plus any literal text you like."/>
            </StackPanel>
            <TextBlock Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="10" Margin="48,4,0,0" TextWrapping="Wrap"
                       Text="Tokens: {datetime} {date} {time} {time12} · {t:FORMAT} for a custom date format"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Where" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2196;"
                             IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=0}" ToolTip="Top-left"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2197;"
                             IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=1}" ToolTip="Top-right"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2199;"
                             IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=2}" ToolTip="Bottom-left"/>
                <RadioButton Style="{StaticResource Seg}" GroupName="ovpos" Content="&#x2198;"
                             IsChecked="{Binding OverlayPosition, Converter={StaticResource StrEq}, ConverterParameter=3}" ToolTip="Bottom-right"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Font" Style="{StaticResource Muted}" VerticalAlignment="Center" Width="44"/>
                <ComboBox x:Name="fontBox" Style="{StaticResource DarkCombo}" Width="220"
                          SelectedItem="{Binding OverlayFontFamily}"
                          ToolTip="Installed fonts — each shown in its own face.">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="13"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="Size" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,8,0"/>
                <TextBox Text="{Binding OverlayFontSize}" Style="{StaticResource DarkTextBox}" Width="50" TextAlignment="Center"
                         local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"
                         ToolTip="Pixels at the real frame size; 0 = auto-scale to the frame height. No upper limit — rendering caps at the frame height."/>
            </StackPanel>
        </StackPanel>

        <Grid Margin="0,18,0,0">
            <Button Content="Close" Style="{StaticResource BtnPrimary}" HorizontalAlignment="Right"
                    MinWidth="84" IsCancel="True"/>
        </Grid>
    </StackPanel>
</Window>
