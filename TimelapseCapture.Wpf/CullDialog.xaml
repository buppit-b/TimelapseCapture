<Window x:Class="TimelapseCapture.Wpf.CullDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cull frames" Width="600" SizeToContent="Height"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="18">
        <TextBlock Text="CULL FRAMES — REMOVE FUMBLES" Style="{StaticResource CardTitle}"/>
        <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Scrub to a bad frame and mark it. On apply, the marked frames are deleted and the rest renumbered so the video stays gapless. This can't be undone."/>

        <Border Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" Height="300" ClipToBounds="True">
            <Grid>
                <Image x:Name="preview" Stretch="Uniform"/>
                <Border x:Name="markedBadge" Background="#CCE5534B" CornerRadius="4" Padding="8,3" Visibility="Collapsed"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                    <TextBlock Text="MARKED FOR DELETION" Foreground="White" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <Slider x:Name="scrub" Minimum="1" Margin="0,12,0,0"
                IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="10"/>
        <TextBlock x:Name="posText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11" Margin="0,4,0,0"/>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="&#9664; Prev" Style="{StaticResource BtnBase}" Click="OnPrev" Margin="0,0,8,0"/>
            <Button Content="Next &#9654;" Style="{StaticResource BtnBase}" Click="OnNext" Margin="0,0,14,0"/>
            <Button x:Name="markBtn" Content="Mark for deletion" Style="{StaticResource BtnBase}" Click="OnToggleMark"/>
            <TextBlock x:Name="markedCount" Style="{StaticResource Body}" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
            <Button x:Name="applyBtn" Content="Delete marked" Style="{StaticResource BtnPrimary}" Click="OnApply" MinWidth="120"/>
        </StackPanel>
    </StackPanel>
</Window>
