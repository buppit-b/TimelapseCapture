<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <!-- Enables System.Windows.Forms.NotifyIcon for the tray icon. Part of the Windows Desktop SDK
         (same as WPF) — NOT an external NuGet dependency. The tray class aliases the WinForms
         namespace to avoid Application/MessageBox ambiguity with WPF. -->
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>TimelapseCapture.Wpf</RootNamespace>
    <AssemblyName>TimelapseCapture.Wpf</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Product>Timelapse Capture</Product>
    <Version>0.9.4</Version>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TimelapseCapture.Core\TimelapseCapture.Core.csproj" />
  </ItemGroup>

</Project>
