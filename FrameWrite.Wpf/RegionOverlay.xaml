<Window x:Class="FrameWrite.Wpf.RegionOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" IsHitTestVisible="False"
        Focusable="False" ResizeMode="NoResize" WindowStartupLocation="Manual">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Dimension readout, sits in the top-right corner ABOVE the outline (outside the recorded area). -->
        <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#DD161616" CornerRadius="3" Padding="6,1" Margin="0,0,0,2"
                BorderBrush="#3FB950" BorderThickness="1">
            <TextBlock x:Name="dimLabel" Foreground="#3FB950" FontFamily="Consolas" FontSize="11"/>
        </Border>
        <!-- 2px outline in the ring just OUTSIDE the capture region, so it isn't recorded. -->
        <Border Grid.Row="1" BorderBrush="#3FB950" BorderThickness="2" Background="Transparent"/>
    </Grid>
</Window>
