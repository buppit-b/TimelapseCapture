<Window x:Class="FrameWrite.Wpf.RegionEditOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        WindowStartupLocation="Manual" Cursor="Arrow">
    <Grid>
        <Canvas x:Name="canvas">
            <!-- Dim mask: four rectangles around the region leave the region itself clear. -->
            <Rectangle x:Name="dimTop"    Fill="#66000000"/>
            <Rectangle x:Name="dimBottom" Fill="#66000000"/>
            <Rectangle x:Name="dimLeft"   Fill="#66000000"/>
            <Rectangle x:Name="dimRight"  Fill="#66000000"/>

            <!-- Region outline. Transparent fill is still hit-testable → drag the center to move.
                 Follows the active theme's accent (was a fixed green). -->
            <Rectangle x:Name="outline" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" Fill="#11FFFFFF"/>

            <!-- 8 resize handles — accent fill + white ring so they stay clear on any screen content
                 (white pops on dark, the accent fill reads on light), and follow the theme. -->
            <Rectangle x:Name="hNW" Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNWSE"/>
            <Rectangle x:Name="hN"  Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNS"/>
            <Rectangle x:Name="hNE" Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNESW"/>
            <Rectangle x:Name="hE"  Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeWE"/>
            <Rectangle x:Name="hSE" Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNWSE"/>
            <Rectangle x:Name="hS"  Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNS"/>
            <Rectangle x:Name="hSW" Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeNESW"/>
            <Rectangle x:Name="hW"  Width="14" Height="14" Fill="{DynamicResource AccentBrush}" Stroke="White" StrokeThickness="2" Cursor="SizeWE"/>

            <Border x:Name="dimBox" Background="#DD161616" CornerRadius="3" Padding="6,2"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                <TextBlock x:Name="dimText" Foreground="{DynamicResource AccentBrush}" FontFamily="Consolas" FontSize="12"/>
            </Border>
        </Canvas>

        <!-- Toolbar -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,24,0,0"
                Background="#EE161616" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="hintText" Foreground="#E6EDE6" FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Apply" Style="{StaticResource BtnPrimary}" Click="OnApply" Margin="0,0,8,0"/>
                <Button Content="Cancel" Style="{StaticResource BtnBase}" Click="OnCancel"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
