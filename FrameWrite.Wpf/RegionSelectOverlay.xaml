<Window x:Class="FrameWrite.Wpf.RegionSelectOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#33000000"
        Topmost="True" ShowInTaskbar="False" Cursor="Cross"
        WindowStartupLocation="Manual" ResizeMode="NoResize">
    <Canvas x:Name="canvas">
        <!-- Accent stroke (was a stray blue — now matches the edit overlay + the active theme);
             subtle neutral fill so the tint reads on any content while the outline carries the colour. -->
        <Rectangle x:Name="selRect" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" Fill="#22FFFFFF" Visibility="Collapsed"/>
        <Border x:Name="dimBox" Background="#E61E1E1E" CornerRadius="4" Padding="6,3" Visibility="Collapsed"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
            <TextBlock x:Name="dimText" Foreground="#ECECEC" FontFamily="Consolas" FontSize="12"/>
        </Border>
        <Border Canvas.Left="0" Canvas.Top="0" Background="#CC1E1E1E" CornerRadius="6" Padding="12,7" Margin="20">
            <TextBlock Foreground="#ECECEC" FontFamily="Consolas" FontSize="13"
                       Text="Drag to select a capture region   •   Esc to cancel"/>
        </Border>
    </Canvas>
</Window>
