<Window x:Class="FrameWrite.Wpf.CullDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FrameWrite.Wpf"
        Title="Cull frames" Width="900" Height="760" MinWidth="680" MinHeight="600"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
        <TextBlock Text="CULL FRAMES — REMOVE FUMBLES" Style="{StaticResource CardTitle}"/>
        <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Scrub to a bad frame and mark it. On apply, the marked frames are deleted and the rest renumbered so the video stays gapless. This can't be undone."/>
        </StackPanel>

        <!-- The badge sits OUTSIDE the zoom viewport so it stays put (it labels the frame, not a spot on it). -->
        <Grid Grid.Row="1">
            <local:ZoomHost Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1">
                <Image x:Name="preview" Stretch="Uniform"/>
            </local:ZoomHost>
            <Border x:Name="markedBadge" Background="#CCE5534B" CornerRadius="4" Padding="8,3" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                <TextBlock Text="MARKED FOR DELETION" Foreground="White" FontFamily="Consolas" FontSize="11" FontWeight="Bold"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2">
        <!-- Red ticks above the scrubber show WHERE the marked frames sit in the sequence. -->
        <Canvas x:Name="markerCanvas" Height="6" Margin="0,10,0,-8" IsHitTestVisible="False"/>
        <Slider x:Name="scrub" Minimum="1" Margin="0,12,0,0" local:WheelStep.Amount="1"
                IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="10"/>

        <!-- Frame-precise stepping (hold to repeat) — scrubbing alone is too coarse on big sessions. -->
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <RepeatButton Grid.Column="0" Content="&#9664;&#9664; 10" Tag="-10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Back 10 frames (hold to repeat)."/>
            <RepeatButton Grid.Column="1" Content="&#9664; 1" Tag="-1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="6,0,0,0"
                          ToolTip="Back one frame (hold to repeat)."/>
            <TextBlock Grid.Column="2" x:Name="posText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"/>
            <RepeatButton Grid.Column="3" Content="1 &#9654;" Tag="1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="0,0,6,0"
                          ToolTip="Forward one frame (hold to repeat)."/>
            <RepeatButton Grid.Column="4" Content="10 &#9654;&#9654;" Tag="10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Forward 10 frames (hold to repeat)."/>
        </Grid>

        <!-- Metadata for the current frame (dimensions · file size · capture time). -->
        <TextBlock x:Name="metaText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="10"
                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

        <TextBlock Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"
                   Text="Keys:  &#8592;/&#8594; step 1  ·  Shift+&#8592;/&#8594; step 10  ·  Space/M mark  ·  Shift+Space mark range  ·  Ctrl+Space unmark range  (ranges run from the last mark action to here)  ·  wheel zoom  ·  middle-drag pan"/>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="markBtn" Content="Mark for deletion" Style="{StaticResource BtnBase}" Click="OnToggleMark"
                    ToolTip="Mark (or unmark) this frame. Shift+click marks — and Ctrl+click unmarks — the whole range from the last mark action to here: anchor one end, scrub to the other, modifier+click."/>
            <Button Content="Clear marks" Style="{StaticResource BtnBase}" Click="OnClearMarks" Margin="8,0,0,0"
                    ToolTip="Unmark everything."/>
            <TextBlock x:Name="markedCount" Style="{StaticResource Body}" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
            <Button x:Name="applyBtn" Content="Delete marked" Style="{StaticResource BtnPrimary}" Click="OnApply" MinWidth="120"/>
        </StackPanel>
        </StackPanel>
    </Grid>
</Window>
