<UserControl x:Class="FrameWrite.Wpf.Sparkline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- A dependency-free line-with-fill sparkline: the code-behind rebuilds the geometry against
         the real render size on data/size change, so the stroke stays crisp (no Viewbox scaling). -->
    <Grid x:Name="host" ClipToBounds="True" SizeChanged="OnSizeChanged" Background="Transparent">
        <Polygon x:Name="fill" Fill="{DynamicResource AccentBrush}" Opacity="0.14"/>
        <Polyline x:Name="line" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                  StrokeLineJoin="Round"/>
    </Grid>
</UserControl>
