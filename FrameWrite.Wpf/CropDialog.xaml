<Window x:Class="FrameWrite.Wpf.CropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FrameWrite.Wpf"
        Title="Crop" Width="900" Height="780" MinWidth="680" MinHeight="620"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
        <TextBlock Text="CROP — FRAME AREA USED IN THE VIDEO" Style="{StaticResource CardTitle}"/>
        <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                   Text="Drag on the frame to choose the area the encode keeps — drag inside to move it, edges and corners to fine-tune (corners keep the ratio; Shift frees). Wheel zooms, middle-drag pans. Non-destructive: frames on disk stay full size — the crop is applied when the video is made (Encode and Trim)."/>
        </StackPanel>

        <!-- ZoomHost: wheel zoom (pixel-crisp past 2×) + middle-drag pan; the crop's left-drag and
             its display↔frame mapping are untouched by the zoom (layout sizes don't transform). -->
        <local:ZoomHost Grid.Row="1" Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1">
            <Grid>
                <Image x:Name="preview" Stretch="Uniform"/>
                <Canvas x:Name="rectCanvas" Background="Transparent" Cursor="Cross"
                        MouseLeftButtonDown="OnCanvasDown" MouseMove="OnCanvasMove" MouseLeftButtonUp="OnCanvasUp"/>
            </Grid>
        </local:ZoomHost>

        <StackPanel Grid.Row="2">
        <!-- Scrub to any frame — later frames may show the content that informs the crop. -->
        <Slider x:Name="scrub" Minimum="1" Margin="0,10,0,0" local:WheelStep.Amount="1"
                IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="10"/>
        <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <RepeatButton Grid.Column="0" Content="&#9664;&#9664; 10" Tag="-10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Back 10 frames (hold to repeat)."/>
            <RepeatButton Grid.Column="1" Content="&#9664; 1" Tag="-1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="6,0,0,0"
                          ToolTip="Back one frame (hold to repeat)."/>
            <TextBlock Grid.Column="2" x:Name="posText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"/>
            <RepeatButton Grid.Column="3" Content="1 &#9654;" Tag="1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="0,0,6,0"
                          ToolTip="Forward one frame (hold to repeat)."/>
            <RepeatButton Grid.Column="4" Content="10 &#9654;&#9654;" Tag="10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Forward 10 frames (hold to repeat)."/>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Ratio" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <RadioButton Style="{StaticResource Seg}" GroupName="cropratio" Content="Free" IsChecked="True" Tag="0:0" Click="OnRatio"/>
            <RadioButton Style="{StaticResource Seg}" GroupName="cropratio" Content="16:9" Tag="16:9" Click="OnRatio"/>
            <RadioButton Style="{StaticResource Seg}" GroupName="cropratio" Content="4:3" Tag="4:3" Click="OnRatio"/>
            <RadioButton Style="{StaticResource Seg}" GroupName="cropratio" Content="1:1" Tag="1:1" Click="OnRatio"/>
            <RadioButton Style="{StaticResource Seg}" GroupName="cropratio" Content="9:16" Tag="9:16" Click="OnRatio"/>
            <ToggleButton x:Name="flipToggle" Style="{StaticResource HeaderToggle}" Content="&#8646;" FontSize="13" Margin="10,0,0,0"
                          Click="OnFlip" VerticalAlignment="Center"
                          ToolTip="Rotate the current selection 90° (swap its width and height about its centre) — works on any ratio, including Free — and flip the locked ratio for future drags."/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="X" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="xBox" Style="{StaticResource DarkTextBox}" Width="56" TextAlignment="Center"
                     local:NumericInput.AllowDecimal="False" LostFocus="OnFieldChanged"/>
            <TextBlock Text="Y" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="yBox" Style="{StaticResource DarkTextBox}" Width="56" TextAlignment="Center"
                     local:NumericInput.AllowDecimal="False" LostFocus="OnFieldChanged"/>
            <TextBlock Text="W" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="wBox" Style="{StaticResource DarkTextBox}" Width="56" TextAlignment="Center"
                     local:NumericInput.AllowDecimal="False" LostFocus="OnFieldChanged"/>
            <TextBlock Text="H" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="hBox" Style="{StaticResource DarkTextBox}" Width="56" TextAlignment="Center"
                     local:NumericInput.AllowDecimal="False" LostFocus="OnFieldChanged"/>
            <TextBlock x:Name="cropInfo" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       VerticalAlignment="Center" Margin="14,0,0,0"/>
        </StackPanel>

        <TextBlock x:Name="overlayHint" Style="{StaticResource Muted}" FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Overlay note: your text overlay is burned into frames at capture time — make sure it sits INSIDE this crop (the Overlay dialog's preview shows the crop area), or it will be cut off in the video."/>

        <Grid Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Clear crop" Style="{StaticResource BtnBase}" Click="OnClear" Margin="0,0,8,0"
                        ToolTip="Remove the crop — encodes use the full frame again."/>
                <Button x:Name="destructiveBtn" Content="Crop frames on disk&#8230;" Style="{StaticResource BtnBase}" Click="OnDestructive"
                        ToolTip="Power user: permanently re-write every frame cropped to this area, reclaiming disk space. Can't be undone. Frames captured afterwards are scaled to the cropped size to stay consistent."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
                <Button Content="Apply" Style="{StaticResource BtnPrimary}" Click="OnApply" MinWidth="100"
                        ToolTip="Save this crop for the session — Encode and Trim will use it."/>
            </StackPanel>
        </Grid>
        </StackPanel>
    </Grid>
</Window>
