<Window x:Class="FrameWrite.Wpf.FrameViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FrameWrite.Wpf"
        Title="Frame viewer" Width="920" Height="680" MinWidth="560" MinHeight="420"
        Background="{DynamicResource BgBrush}" WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" ShowInTaskbar="False" Style="{StaticResource DialogWindow}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The loupe: wheel zooms at the cursor, drag pans, double-click toggles fit ↔ 1:1. -->
        <Border Background="#0A0A0A" CornerRadius="6" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" ClipToBounds="True">
            <Grid x:Name="viewport" Background="Transparent" Cursor="Cross"
                  MouseWheel="OnWheelZoom" MouseLeftButtonDown="OnViewportDown"
                  MouseMove="OnViewportMove" MouseLeftButtonUp="OnViewportUp"
                  SizeChanged="OnViewportSized">
                <Image x:Name="img" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"
                       RenderTransformOrigin="0,0">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="scaleT"/>
                            <TranslateTransform x:Name="transT"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Grid>
        </Border>

        <!-- Zoom + frame info. -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="playBtn" Content="&#9654; Play" Style="{StaticResource BtnBase}" FontSize="11" Padding="10,3" Click="OnPlayToggle"
                        ToolTip="Play the timelapse at the encode fps so you can preview the result before encoding (loops; any step pauses it)."/>
                <TextBlock x:Name="fpsText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Border Width="1" Background="{DynamicResource StrokeBrush}" Margin="12,2,12,2"/>
                <Button Content="Fit" Style="{StaticResource BtnBase}" FontSize="11" Padding="10,3" Click="OnFit"
                        ToolTip="Fit the whole frame in the window (re-fits as you resize until you zoom manually)."/>
                <Button Content="1:1" Style="{StaticResource BtnBase}" FontSize="11" Padding="10,3" Margin="6,0,0,0" Click="OnActualSize"
                        ToolTip="100% — one frame pixel per screen pixel."/>
                <TextBlock x:Name="zoomText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="infoText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="&#x21BB;" Style="{StaticResource BtnBase}" FontSize="12" Padding="8,2" Click="OnRefresh"
                        ToolTip="Re-scan the session for new frames (useful while capture is running)."/>
            </StackPanel>
        </Grid>

        <!-- Scrub through the session's frames (wheel steps one frame at a time). -->
        <Slider Grid.Row="2" x:Name="scrub" Minimum="1" Margin="0,10,0,0" local:WheelStep.Amount="1"
                IsSnapToTickEnabled="True" TickFrequency="1" SmallChange="1" LargeChange="10"
                ValueChanged="OnScrub"/>
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <RepeatButton Grid.Column="0" Content="&#9664;&#9664; 10" Tag="-10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Back 10 frames (hold to repeat)."/>
            <RepeatButton Grid.Column="1" Content="&#9664; 1" Tag="-1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="6,0,0,0"
                          ToolTip="Back one frame (hold to repeat)."/>
            <TextBlock Grid.Column="2" x:Name="posText" Style="{StaticResource Muted}" FontFamily="Consolas" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,0"/>
            <RepeatButton Grid.Column="3" Content="1 &#9654;" Tag="1" Style="{StaticResource BtnStep}" Click="OnStep" Margin="0,0,6,0"
                          ToolTip="Forward one frame (hold to repeat)."/>
            <RepeatButton Grid.Column="4" Content="10 &#9654;&#9654;" Tag="10" Style="{StaticResource BtnStep}" Click="OnStep"
                          ToolTip="Forward 10 frames (hold to repeat)."/>
        </Grid>
    </Grid>
</Window>
