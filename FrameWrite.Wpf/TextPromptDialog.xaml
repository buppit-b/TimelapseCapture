<Window x:Class="FrameWrite.Wpf.TextPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" SizeToContent="Height" Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}">
    <StackPanel Margin="18">
        <TextBlock x:Name="promptLabel" Style="{StaticResource Muted}" Margin="0,0,0,8"/>
        <TextBox x:Name="input" Style="{StaticResource DarkTextBox}" FontSize="14" Padding="8,6"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" IsCancel="True"/>
            <Button Content="OK" Style="{StaticResource BtnPrimary}" Click="OnOk" MinWidth="84" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
