<Window x:Class="FrameWrite.Wpf.CombineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FrameWrite.Wpf"
        Title="Combine sessions" Width="780" Height="740" MinWidth="680" MinHeight="580"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}"
        MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}" Closing="OnClosing">
    <Window.Resources>
        <!-- The aligned label column that keeps the settings form from looking ragged. -->
        <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource Muted}">
            <Setter Property="Width" Value="64"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FormRow" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="COMBINE SESSIONS" Style="{StaticResource CardTitle}"/>
            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"
                       Text="One continuous video, oldest first. Cull and Crop prepare a session in place; ✕ leaves it out. Settings below apply to this combine only."/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" CornerRadius="10" Padding="6" MinHeight="120">
            <ListBox x:Name="list" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="Transparent" CornerRadius="6" Padding="8,7" Margin="0,1">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel LastChildFill="True">
                            <!-- Per-session prep: the REAL cull/crop dialogs, opened for that session. -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Cull…" Style="{StaticResource BtnBase}" Padding="10,4" Margin="0,0,6,0"
                                        Click="OnCullRow" Tag="{Binding}"
                                        ToolTip="Scrub this session and delete fumble frames (renumbers gapless — can't be undone; backup offered)."/>
                                <Button Content="Crop…" Style="{StaticResource BtnBase}" Padding="10,4" Margin="0,0,6,0"
                                        Click="OnCropRow" Tag="{Binding}"
                                        ToolTip="Choose the frame area this session contributes (saved on the session; non-destructive by default)."/>
                                <Button Content="✕" Style="{StaticResource BtnBase}" Padding="8,4"
                                        Click="OnRemoveRow" Tag="{Binding}"
                                        ToolTip="Leave this session out (the session itself is untouched)."/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontFamily="Consolas" FontSize="13"/>
                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Per-combine encode settings: SEEDED from the app's, applied here only — the main
             window doesn't move while you tweak. Aligned label column; conditional rows collapse. -->
        <Border Grid.Row="2" x:Name="settingsPanel" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="10"
                Padding="14,10,14,12" Margin="0,12,0,0">
            <StackPanel>
                <StackPanel Style="{StaticResource FormRow}" Margin="0">
                    <TextBlock Text="Format" Style="{StaticResource FormLabel}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbfmt" Content="MP4"
                                 IsChecked="{Binding Format, Converter={StaticResource StrEq}, ConverterParameter=mp4}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbfmt" Content="WebM"
                                 IsChecked="{Binding Format, Converter={StaticResource StrEq}, ConverterParameter=webm}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbfmt" Content="GIF"
                                 IsChecked="{Binding Format, Converter={StaticResource StrEq}, ConverterParameter=gif}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Length" Style="{StaticResource FormLabel}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbunit" Content="fps"
                                 IsChecked="{Binding UnitIndex, Converter={StaticResource StrEq}, ConverterParameter=0}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbunit" Content="exact length"
                                 IsChecked="{Binding UnitIndex, Converter={StaticResource StrEq}, ConverterParameter=1}"/>
                    <StackPanel Orientation="Horizontal" Margin="14,0,0,0"
                                Visibility="{Binding ShowFps, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding Fps}" Style="{StaticResource DarkTextBox}" Width="44" TextAlignment="Center"
                                 local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"/>
                        <TextBlock Text="fps" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="14,0,0,0"
                                Visibility="{Binding ShowLength, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding DurationSeconds}" Style="{StaticResource DarkTextBox}" Width="52" TextAlignment="Center"
                                 local:NumericInput.AllowDecimal="True" local:ClampFlash.Enabled="True"/>
                        <TextBlock Text="s" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}"
                            Visibility="{Binding ShowTuning, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Quality" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="CRF" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Crf}" Style="{StaticResource DarkTextBox}" Width="44" TextAlignment="Center"
                             local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"
                             ToolTip="Quality (CRF 0–51): LOWER is better and bigger."/>
                    <TextBlock Text="Preset" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbpreset" Content="Fast"
                                 IsChecked="{Binding Preset, Converter={StaticResource StrEq}, ConverterParameter=ultrafast}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbpreset" Content="Medium"
                                 IsChecked="{Binding Preset, Converter={StaticResource StrEq}, ConverterParameter=medium}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbpreset" Content="Slow"
                                 IsChecked="{Binding Preset, Converter={StaticResource StrEq}, ConverterParameter=veryslow}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}"
                            Visibility="{Binding IsGif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Palette" Style="{StaticResource FormLabel}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifc" Content="256"
                                 IsChecked="{Binding GifColors, Converter={StaticResource StrEq}, ConverterParameter=256}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifc" Content="128"
                                 IsChecked="{Binding GifColors, Converter={StaticResource StrEq}, ConverterParameter=128}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifc" Content="64"
                                 IsChecked="{Binding GifColors, Converter={StaticResource StrEq}, ConverterParameter=64}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifc" Content="32"
                                 IsChecked="{Binding GifColors, Converter={StaticResource StrEq}, ConverterParameter=32}"/>
                    <TextBlock Text="Dither" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifd" Content="Pattern"
                                 IsChecked="{Binding GifDither, Converter={StaticResource StrEq}, ConverterParameter=bayer}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifd" Content="Smooth"
                                 IsChecked="{Binding GifDither, Converter={StaticResource StrEq}, ConverterParameter=floyd}"/>
                    <RadioButton Style="{StaticResource Seg}" GroupName="cmbgifd" Content="None"
                                 IsChecked="{Binding GifDither, Converter={StaticResource StrEq}, ConverterParameter=none}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}"
                            Visibility="{Binding IsGif, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Caps" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="fps ≤" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding GifMaxFps}" Style="{StaticResource DarkTextBox}" Width="40" TextAlignment="Center"
                             local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"/>
                    <TextBlock Text="width ≤" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <TextBox Text="{Binding GifMaxWidth}" Style="{StaticResource DarkTextBox}" Width="52" TextAlignment="Center"
                             local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"/>
                    <TextBlock Text="px" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="Speed" Style="{StaticResource FormLabel}"/>
                    <CheckBox Content="keep 1 frame in every" IsChecked="{Binding SpeedUpEnabled}"
                              Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" VerticalAlignment="Center"
                              ToolTip="Applies to the JOINED timeline, so the thinning is uniform across session boundaries."/>
                    <TextBox Text="{Binding SpeedUpN}" Style="{StaticResource DarkTextBox}" Width="40" TextAlignment="Center" Margin="6,0,0,0"
                             local:NumericInput.AllowDecimal="False" local:ClampFlash.Enabled="True"
                             Visibility="{Binding SpeedUpEnabled, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <StackPanel Style="{StaticResource FormRow}">
                    <TextBlock Text="End" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="hold the last frame" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding HoldLastSeconds}" Style="{StaticResource DarkTextBox}" Width="44" TextAlignment="Center"
                             local:NumericInput.AllowDecimal="True" local:ClampFlash.Enabled="True"
                             ToolTip="Clone the final frame this long so the finished piece lingers. 0 = off."/>
                    <TextBlock Text="s" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Live outcome: frames → length, canvas — recomputed as the list or settings change. -->
                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="6" Padding="10,6" Margin="0,12,0,0">
                    <TextBlock x:Name="resultText" Style="{StaticResource Muted}" FontFamily="Consolas"
                               FontSize="11" Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="progressText" Foreground="{DynamicResource TextSecondaryBrush}"
                       FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="closeBtn" Content="Close" Style="{StaticResource BtnBase}" Margin="0,0,8,0" MinWidth="84" Click="OnCloseBtn"/>
                <Button x:Name="combineBtn" Content="Combine" Style="{StaticResource BtnPrimary}" MinWidth="110" Click="OnCombine"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
