<Window x:Class="FrameWrite.Wpf.LoadSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Session" Height="520" Width="460"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinHeight="320" MinWidth="380" ShowInTaskbar="False"
        Style="{StaticResource DialogWindow}" Closing="OnClosing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="SESSIONS" Style="{StaticResource CardTitle}"/>
                <TextBlock Text="Ctrl/Shift-click selects several — Combine… turns them into one video."
                           Style="{StaticResource Muted}" FontSize="10" Margin="0,0,0,6"/>
            </StackPanel>
            <!-- Sort (shared with the combine dialog): field + direction. Date is first and default. -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <RadioButton x:Name="sortDate" Style="{StaticResource Seg}" GroupName="lssort" Content="Date"
                             Checked="OnSortChanged" ToolTip="Sort by session start date."/>
                <RadioButton x:Name="sortFrames" Style="{StaticResource Seg}" GroupName="lssort" Content="Frames"
                             Checked="OnSortChanged" ToolTip="Sort by frame count."/>
                <RadioButton x:Name="sortSize" Style="{StaticResource Seg}" GroupName="lssort" Content="Size"
                             Checked="OnSortChanged" ToolTip="Sort by capture-area size (pixels)."/>
                <ToggleButton x:Name="sortDir" Style="{StaticResource HeaderToggle}" FontSize="12" Margin="6,0,0,0"
                              Click="OnSortChanged" VerticalAlignment="Center"
                              ToolTip="Flip the direction (↓ largest/newest first)."/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1" CornerRadius="10" Padding="6">
            <Grid>
                <ListBox x:Name="list" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Extended"
                         MouseDoubleClick="OnDoubleClick" SelectionChanged="OnSelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                                BorderThickness="1" BorderBrush="Transparent" Padding="8,7" Margin="0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="60" Height="36" Margin="0,0,12,0" CornerRadius="3"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1"
                                        ClipToBounds="True" SnapsToDevicePixels="True">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontFamily="Consolas" FontSize="14"/>
                                        <Border CornerRadius="3" BorderThickness="1" Padding="5,1" Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}"
                                                ToolTip="Frames are packed into one archive file — load (or Unarchive) to restore them.">
                                            <TextBlock Text="ARCHIVED" Foreground="{DynamicResource AccentBrush}"
                                                       FontFamily="Consolas" FontSize="9"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontFamily="Consolas" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="emptyMsg" Visibility="Collapsed"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                           Text="No sessions in this output folder yet.&#x0a;Use New Session to create one."/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <!-- Left: storage management (Archive/Unarchive per selected row) + live progress. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="archiveBtn" Content="Archive" Style="{StaticResource BtnBase}"
                        Click="OnArchive" MinWidth="84" Visibility="Collapsed"/>
                <Button x:Name="combineBtn" Content="Combine…" Style="{StaticResource BtnBase}"
                        Click="OnCombine" MinWidth="84" Margin="0,0,6,0"/>
                <TextBlock x:Name="progressText" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="10,0,8,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="cancelBtn" Content="Cancel" Style="{StaticResource BtnBase}" Margin="0,0,8,0" Click="OnCancel" MinWidth="84"/>
                <Button x:Name="loadBtn" Content="Load" Style="{StaticResource BtnPrimary}" Click="OnLoad" MinWidth="84"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
